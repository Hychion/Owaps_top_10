# Copy to .env and fill in values — never commit .env
# Environment variables override config.yaml

OWASP_TESTER_HTTP_TIMEOUT=15
OWASP_TESTER_HTTP_VERIFY_TLS=true
OWASP_TESTER_SCANNER_CONCURRENCY=5
OWASP_TESTER_LOG_LEVEL=info

# Optional: proxy for traffic inspection (e.g. Burp Suite)
# OWASP_TESTER_HTTP_PROXY=http://127.0.0.1:8080

# Lab credentials (used only by integration tests)
# LAB_URL=http://localhost:3000
# LAB_USERNAME=admin
# LAB_PASSWORD=admin
